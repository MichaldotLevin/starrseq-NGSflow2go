/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Base process configuration
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Resource allocation based on process labels
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {
    // Error strategy
    errorStrategy = { task.exitStatus in [143,137,104,134,139] ? 'retry' : 'finish' }
    maxRetries    = 1
    maxErrors     = '-1'

    // Resource labels - these match labels assigned in process definitions
    withLabel: 'process_single' {
        cpus   = 1
        memory = 4.GB
        time   = 4.h
    }

    withLabel: 'process_low' {
        cpus   = 2
        memory = 8.GB
        time   = 6.h
    }

    withLabel: 'process_medium' {
        cpus   = 6
        memory = 24.GB
        time   = 12.h
    }

    withLabel: 'process_high' {
        cpus   = 12
        memory = 64.GB
        time   = 24.h
    }

    withLabel: 'process_long' {
        time   = 48.h
    }

    withLabel: 'process_high_memory' {
        memory = 128.GB
    }

    withLabel: 'error_ignore' {
        errorStrategy = 'ignore'
    }

    withLabel: 'error_retry' {
        errorStrategy = 'retry'
        maxRetries    = 2
    }
}
