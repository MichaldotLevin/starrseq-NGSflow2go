/*
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Module-specific configuration
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
    Process-specific parameter overrides and publishDir settings
~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~~
*/

process {
    // FastQC
    withName: 'FASTQC' {
        ext.args = '--quiet'
    }

    // Cutadapt
    withName: 'CUTADAPT' {
        ext.args = [
            params.clip_r1 ? "-u ${params.clip_r1}" : '',
            params.clip_r2 ? "-U ${params.clip_r2}" : '',
            params.three_prime_clip_r1 ? "-u -${params.three_prime_clip_r1}" : '',
            params.three_prime_clip_r2 ? "-U -${params.three_prime_clip_r2}" : '',
            params.adapter_seq ? "-a ${params.adapter_seq}" : ''
        ].join(' ').trim()
    }

    // Bowtie2
    withName: 'BOWTIE2_ALIGN' {
        ext.args = [
            params.bowtie2_opts ?: '',
            params.multimappers ? "-k ${params.multimappers}" : ''
        ].join(' ').trim()
    }

    // Samtools
    withName: 'SAMTOOLS_SORT' {
        ext.args = '-m 2G'
    }

    withName: 'SAMTOOLS_RMDUP' {
        ext.args = params.paired_end ? '' : '-s'
    }

    // Picard
    withName: 'PICARD_MARKDUPLICATES' {
        ext.args = 'REMOVE_DUPLICATES=false VALIDATION_STRINGENCY=LENIENT'
    }

    // MACS2
    withName: 'MACS2_CALLPEAK' {
        ext.args = [
            params.macs2_gsize ? "-g ${params.macs2_gsize}" : '-g hs',
            params.macs2_opts ?: ''
        ].join(' ').trim()
    }

    // deepTools bamCoverage
    withName: 'DEEPTOOLS_BAMCOVERAGE' {
        ext.args = [
            '--binSize 10',
            '--normalizeUsing RPKM',
            params.bamcoverage_opts ?: ''
        ].join(' ').trim()
    }

    // Subread featureCounts
    withName: 'SUBREAD_FEATURECOUNTS' {
        ext.args = [
            params.paired_end ? '-p' : '',
            '-t exon',
            '-g gene_id',
            params.featurecounts_opts ?: ''
        ].join(' ').trim()
    }

    // DESeq2
    withName: 'DESEQ2_DIFFERENTIAL' {
        ext.args = [
            params.deseq2_fdr ? "--fdr ${params.deseq2_fdr}" : '--fdr 0.05',
            params.deseq2_lfc ? "--lfc ${params.deseq2_lfc}" : '--lfc 1.0'
        ].join(' ').trim()
    }

    // MultiQC
    withName: 'MULTIQC' {
        ext.args = params.multiqc_title ? "--title \"${params.multiqc_title}\"" : ''
    }
}
